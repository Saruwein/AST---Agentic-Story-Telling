{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
  },
  "provider": {
    "kiconnectnrw:rwth": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "kiconnectnrw:rwth",
      "options": {
        "baseURL": "https://chat.kiconnect.nrw/api/v1",
        "apiKey": "_YOUR_API_KEY_HERE_",
      },
      "models": {
        "rwth/gpt-oss-120b": {
          "id": "gpt-oss-120b",
          "name": "GPT-OSS-120B",
          "limit": {
            "context": 131072,
            "output": 8192,
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"],
          },
        },
        "rwth/mistral-small-4-119b-2603": {
          "id": "mistral-small-4-119b-2603",
          "name": "mistral-small-4-119b-2603",
          "limit": {
            "context": 262144,
            "output": 64000,
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "rwth/gpt-5.4-mini": {
          "id": "gpt-5.4-mini",
          "name": "GPT-5.4 Mini",
          "limit": {
            "context": 400000,
            "output": 128000,
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "rwth/gpt-5.2": {
          "id": "gpt-5.2",
          "name": "GPT-5.2",
          "limit": {
            "context": 400000,
            "output": 128000,
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
      },
    },
    "kiconnectnrw:fhaachen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "kiconnectnrw:fhaachen",
      "options": {
        "baseURL": "https://chat.kiconnect.nrw/api/v1",
        "apiKey": "_YOUR_API_KEY_HERE_",
      },
      "models": {
        "fhaachen/gpt-5-nano": {
          "id": "gpt-5-nano",
          "name": "GPT-5 Nano",
          "limit": {
            "context": 192000,
            "output": 65536,
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"],
          },
        },
        "fhaachen/gpt-5.2": {
          "id": "gpt-5.2",
          "name": "GPT-5.2",
          "limit": {
            "context": 192000,
            "output": 65536,
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"],
          },
        },
        "fhaachen/gpt-oss-120b": {
          "id": "gpt-oss-120b",
          "name": "GPT-OSS-120B",
          "limit": {
            "context": 131072,
            "output": 8192,
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"],
          },
        },
      },
    },
  },
}